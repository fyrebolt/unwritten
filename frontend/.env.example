# ─── Clerk (auth) ──────────────────────────────────────────────────────────
# Create an instance at https://dashboard.clerk.com → API keys → Quickstart.
# Magic link: enable Email + (optional) Google in User & Authentication → Email,
# Phone, Username and Social Connections.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/signin
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────
# An M0 free-tier cluster is enough for the hackathon. The frontend talks to
# Mongo directly via Next API routes (see app/api/cases, app/api/users/sync).
# DB name defaults to `unwritten`.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=unwritten

# ─── Agents service (Python intake → policy → evidence → drafting) ─────────
# Run: `python -m agents.main_api` (defaults to http://127.0.0.1:8788).
# /api/cases/[id]/agents/run proxies to ${AGENTS_API_URL}/v1/intake.
AGENTS_API_URL=http://127.0.0.1:8788

# ─── Hono backend (legacy denial parse + Whisper transcription) ────────────
# Used directly from the browser by the new-case wizard. Run: `pnpm dev:backend`.
NEXT_PUBLIC_API_URL=http://localhost:8787

# ─── Cloudinary (https://console.cloudinary.com/) ──────────────────────────
# Create an unsigned upload preset called `unwritten_denials` and set
# UPLOAD_PRESET below to its name. Per-user folder is set automatically at
# upload time (`users/<clerkUserId>/denials`).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dtuelki2p
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=unwritten_unsigned
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_FOLDER=unwritten/denials   # optional default
