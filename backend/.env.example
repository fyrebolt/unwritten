PORT=8787
# Optional: improves PDF field extraction and image denials (vision) + Whisper transcription
OPENAI_API_KEY=

# Same Cloudinary cloud as the frontend — enables signed fetch when anonymous delivery returns 401 (common for raw/PDF).
# Easiest: paste the full string from the Cloudinary console (Dashboard → API Keys → "Copy environment variable").
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set the three values below (do not commit real secrets).
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
