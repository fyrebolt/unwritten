# =============================================================================
# Backend env template
# Copy to backend/.env and fill values before running backend.
# =============================================================================

# Core server/auth
PORT=8787
MONGO_URI=mongodb://127.0.0.1:27017/unwritten
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM providers (set at least one for parsing/transcription flows)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional provider model overrides
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_PARSE_MODEL=claude-haiku-4-5
# ANTHROPIC_INTAKE_TRANSCRIBE_MODEL=claude-haiku-4-5

# Local Whisper mode (optional, instead of OpenAI Whisper API)
# LOCAL_WHISPER=1
# WHISPER_MODEL=tiny
# WHISPER_LANGUAGE=en
# WHISPER_PYTHON=python3
# WHISPER_CLI=/path/to/whisper
# WHISPER_TIMEOUT_MS=1800000

# Cloudinary (set either CLOUDINARY_URL or all three split values)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# =============================================================================
# Multi-agent (Fetch.ai uagents) configuration
# =============================================================================
#
# Topology selection (see agents/run_bureau.py):
#   - REMOTE: only BridgeAgent runs locally; pipeline agents live on
#     Agentverse. Track-credible (real cross-network traffic). Requires both
#     AGENTVERSE_API_KEY and REMOTE_INTAKE_ADDRESS below.
#   - LOCAL:  all five agents run in one Bureau process locally. Used as a
#     fallback when keys aren't set, or forced via AGENTS_LOCAL_BUREAU=1.
#
# Get an Agentverse API key at: https://agentverse.ai/profile/api-keys
# AGENTVERSE_API_KEY=
#
# Live IntakeAgent address from Agentverse (BridgeAgent dispatches here in
# REMOTE mode). It's printed at startup when the team's IntakeAgent registers.
# REMOTE_INTAKE_ADDRESS=agent1q...
#
# Force LOCAL mode (useful for offline demos / when Agentverse is flaky):
# AGENTS_LOCAL_BUREAU=1
#
# Bureau / HTTP-bridge timeouts (seconds). Defaults are fine for the demo.
# AGENTS_BRIDGE_TIMEOUT=240
# BUREAU_PORT=8200
