# =============================================================================
# This file is NOT read at runtime — docs / template only.
# Put secrets in:  backend/.env   (same directory as this file)
# Quick start:    cp .env.example .env
# Then edit .env and restart the API (e.g. pnpm dev from the backend package).
# =============================================================================

PORT=8787
# Denial PDF/images: secondary native PDF + vision after Anthropic (Google AI Studio key).
GEMINI_API_KEY=
# Or use the same key under GOOGLE_API_KEY=
# Optional: gemini-2.0-flash, gemini-2.5-flash-preview-05-20, etc.
# GEMINI_MODEL=gemini-2.0-flash

# Intake voice (/v1/intake/transcribe): either open-source Whisper on this machine OR the Whisper API.
# Open-source (no OpenAI bill): https://github.com/openai/whisper — install ffmpeg + `pip install -U openai-whisper`, then:
# LOCAL_WHISPER=1
# Optional: WHISPER_MODEL=tiny (default; faster first run), WHISPER_LANGUAGE=en, WHISPER_PYTHON=python3, WHISPER_CLI=/path/to/whisper
# WHISPER_TIMEOUT_MS=1800000  (30m; first model download can be slow)
OPENAI_API_KEY=

# Denial PDF/images (primary): Claude Messages + native PDF / vision. Optional: claude-sonnet-4-6 if a model rejects PDFs.
ANTHROPIC_API_KEY=
# ANTHROPIC_PARSE_MODEL=claude-haiku-4-5
# Optional: Claude polishes the draft STT transcript for “what happened” (fixes errors; does not hear raw audio).
# ANTHROPIC_INTAKE_TRANSCRIBE_MODEL=claude-haiku-4-5

# Same Cloudinary cloud as the frontend — enables signed fetch when anonymous delivery returns 401 (common for raw/PDF).
# Loaded automatically from backend/.env (see src/load-env.ts) — restart the API after edits.
# Easiest: paste the full line from Cloudinary (Dashboard → API Keys → "Copy environment variable").
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or all three below. API_KEY is the numeric key shown above API Secret (all three are required for signing).
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
